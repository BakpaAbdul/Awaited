# ─── Awaited Environment Variables ────────────────────────────────
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Shared backend (Phase 2 — leave blank to stay on browser-local persistence)
# Use the same VITE_* values in Vercel Project Settings for production.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_ADMIN_FUNCTION=admin-actions

# Admin password for browser-local fallback only.
# For Supabase mode, set AWAITED_ADMIN_PASSWORD as an Edge Function secret instead.
VITE_ADMIN_PASSWORD=scholar2026
